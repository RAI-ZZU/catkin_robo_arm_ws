<!-- 启动panda机械臂，主要是速度控制器等底层启动 -->
<launch>
  <arg name="arm_id" default="panda"/>
  <arg name="robot_ip" default="192.168.5.245"/>

  <!-- robot_description 放这里更合理，因为 franka_control 也依赖它 -->
  <param name="robot_description"
         command="$(find xacro)/xacro '$(find franka_description)/robots/panda/panda_arm_hand.urdf.xacro' arm_id:=$(arg arm_id)" />

  <!-- 真实 Panda 控制 -->
  <node name="franka_control" pkg="franka_control" type="franka_control_node" required="true">
    <rosparam file="$(find franka_control)/config/franka_control_node.yaml" command="load" subst_value="true"/>
    <param name="robot_ip" value="$(arg robot_ip)"/>
    <param name="arm_id" value="$(arg arm_id)"/>
    <remap from="franka_state_controller/joint_states" to="/joint_states"/>
  </node>

  <!-- 夹爪 -->
  <include file="$(find franka_gripper)/launch/franka_gripper.launch">
    <arg name="robot_ip" value="$(arg robot_ip)"/>
  </include>

  <!-- 控制器 -->
  <rosparam file="$(find franka_control)/config/default_controllers.yaml" command="load" subst_value="true"/>
  <node name="ctrl_spawner" pkg="controller_manager" type="spawner"
        args="franka_state_controller velocity_joint_controller"/>

  <!-- 夹爪 joint state relay -->
  <node name="gripper_js_relay" pkg="topic_tools" type="relay"
        args="/franka_gripper/joint_states /joint_states"/>
        
  <!-- 机器人状态发布 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen">
    <param name="publish_frequency" type="double" value="100.0" />
  </node>
</launch>
